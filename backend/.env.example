# ─── Rating Environment ─────────────────────────────────────────────────────────
# test -> FedEx sandbox + Shippo test key
# live -> FedEx production + Shippo live key
RATE_MODE=test

# ─── FedEx Sandbox (Real API) ─────────────────────────────────────────────────
# Get from: https://developer.fedex.com → Create App → Sandbox credentials
FEDEX_CLIENT_ID=your_fedex_client_id_here
FEDEX_CLIENT_SECRET=your_fedex_client_secret_here
FEDEX_ACCOUNT_NUMBER=your_fedex_account_number_here
# Optional override. Leave empty to auto-pick by RATE_MODE.
# FEDEX_BASE_URL=https://apis-sandbox.fedex.com

# ─── Shippo (Real UPS + USPS rates) ────────────────────────────────────────────
# Get from: https://apps.goshippo.com/settings/api
SHIPPO_API_KEY=your_shippo_api_key_here

# ─── LLM (Optional — for AI summary generation) ───────────────────────────────
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ─── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
